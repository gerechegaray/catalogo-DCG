# Variables para scripts/syncAlegra.js (npm run sync:catalog)
# Copiá a .env en la raíz del repo o exportá en la terminal.
# En GitHub Actions se definen en Secrets; dotenv no las sobrescribe.

ALEGRA_API_KEY=tu_clave_aqui
# Opcional (por defecto Alegra v1):
# ALEGRA_BASE_URL=https://api.alegra.com/api/v1
